class TestCase::Alias {
  # use alias
  use Point as PO;
  
  # require alias
  alias Point3D as PO3D;

  static method alias : int () {
    
    # use alias
    {
      my $minimal = PO->new(3);
      unless ($minimal->x == 3) {
        return 0;
      }
    }
    
    # require alias
    if (require Point3D) {
      my $simple = PO3D->new(3);
      unless ($simple->x == 3) {
        return 0;
      }
    }
    
    return 1;
  }
}
