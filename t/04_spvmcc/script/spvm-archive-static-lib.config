use File::Basename 'dirname';

my $config_global = SPVM::Builder::Config::Exe->new;

my $config_dir = dirname __FILE__;

$config_global->use_spvm_archive("$ENV{SPVM_BUILD_DIR}/.tmp/spvm-archive-myapp");

$config_global->add_lib('spvmcc_archive_test');

$config_global->optimize_global('-O0 -g3');

$config_global;
