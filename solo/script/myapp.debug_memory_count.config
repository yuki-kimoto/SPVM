use strict;
use warnings;

use SPVM::Builder::Config::Exe;

my $exe_config = SPVM::Builder::Config::Exe->load_base_config(__FILE__);

$exe_config->add_before_compile_cb(sub {
  my ($config) = @_;
  
  $config->add_define("FOR_TEST1");
  $config->add_define("SPVM_DEBUG_MEMORY");
});

$exe_config->add_before_compile_cb(sub {
  my ($config) = @_;
  
  if ($config->category eq 'spvm_core') {
    $config->add_define("FOR_TEST2");
  }
});

$exe_config->optimize("-O0");

$exe_config;
